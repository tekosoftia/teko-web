---
import { t, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const cards = [
  {
    id: 'SYS_ID_01',
    icon: 'diamond',
    title: t(lang, 'identity.cards.precision.title'),
    desc: t(lang, 'identity.cards.precision.desc'),
    status: (t(lang, 'identity.cards.precision.status') as string).replace('STATUS: ', '').replace('ESTADO: ', ''),
    statusIcon: 'arrow_forward',
    mt: 'md:mt-0',
  },
  {
    id: 'SYS_ID_02',
    icon: 'shield',
    title: t(lang, 'identity.cards.defense.title'),
    desc: t(lang, 'identity.cards.defense.desc'),
    status: (t(lang, 'identity.cards.defense.status') as string).replace('STATUS: ', '').replace('ESTADO: ', ''),
    statusIcon: 'lock',
    mt: 'md:mt-20',
  },
  {
    id: 'SYS_ID_03',
    icon: 'favorite',
    title: t(lang, 'identity.cards.symbiosis.title'),
    desc: t(lang, 'identity.cards.symbiosis.desc'),
    status: (t(lang, 'identity.cards.symbiosis.status') as string).replace('STATUS: ', '').replace('ESTADO: ', ''),
    statusIcon: 'graphic_eq',
    mt: 'md:-mt-10',
  },
  {
    id: 'SYS_ID_04',
    icon: 'visibility',
    title: t(lang, 'identity.cards.openSource.title'),
    desc: t(lang, 'identity.cards.openSource.desc'),
    status: (t(lang, 'identity.cards.openSource.status') as string).replace('STATUS: ', '').replace('ESTADO: ', ''),
    statusIcon: 'code',
    mt: 'md:mt-12',
  },
];
---

<main class="relative z-10 w-full flex-grow flex flex-col items-center py-20 px-4 md:px-8">
  <div class="max-w-7xl w-full mx-auto">
    <!-- Section Header -->
    <header class="mb-16 md:mb-24 relative group">
      <div class="absolute -left-12 top-0 h-full w-[1px] bg-gradient-to-b from-transparent via-accent/50 to-transparent hidden md:block"></div>
      <div class="absolute -left-16 top-4 font-mono text-[10px] text-accent/60 -rotate-90 hidden md:block">{t(lang, 'identity.secLabel')}</div>
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="w-2 h-2 bg-accent rounded-sm animate-pulse"></span>
            <span class="font-mono text-accent text-xs tracking-widest uppercase">{t(lang, 'identity.loaded')}</span>
          </div>
          <h2 class="text-2xl sm:text-4xl md:text-6xl lg:text-7xl font-display font-bold uppercase tracking-tight leading-none text-transparent bg-clip-text bg-gradient-to-r from-white via-white to-white/50">
            {t(lang, 'identity.title1')}<br />
            <span class="text-stroke-1 text-transparent relative">
              {t(lang, 'identity.title2')}
            </span>
          </h2>
        </div>
        <div class="max-w-md text-right md:text-left relative">
          <div class="absolute -top-6 -left-6 text-6xl text-white/5 font-display font-bold select-none -z-10">02</div>
          <p class="text-text-muted text-base md:text-lg leading-relaxed border-l-2 border-accent/30 pl-4">
            {t(lang, 'identity.description')}
          </p>
        </div>
      </div>
    </header>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-x-12 md:gap-y-16 relative">
      <div class="absolute inset-0 border-l border-white/5 -skew-x-12 left-1/2 pointer-events-none hidden md:block"></div>
      {cards.map((card) => (
        <div class={`group relative ${card.mt} hover:z-20`} style="perspective: 1000px;">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-accent to-primary transition duration-500 blur rounded-xl opacity-0 group-hover:opacity-100"></div>
          <div class="glass-panel relative h-full p-8 rounded-xl border-b-2 transition-all duration-500 transform border-b-accent/50 group-hover:-translate-y-2 group-hover:shadow-neon">
            <div class="absolute top-4 right-4 font-mono text-[9px] text-white/20">{card.id}</div>
            <div class="mb-6 inline-flex p-3 rounded-lg border transition-colors bg-white/5 border-white/10 group-hover:bg-accent/20 group-hover:border-accent/50">
              <span class="material-symbols-outlined text-3xl text-accent">{card.icon}</span>
            </div>
            <h3 class="text-xl md:text-2xl font-display font-bold mb-3 transition-colors group-hover:text-accent">{card.title}</h3>
            <p class="text-text-muted font-body text-base md:text-lg">{card.desc}</p>
            <div class="mt-6 pt-4 border-t border-white/5 flex items-center justify-between transition-opacity opacity-50 group-hover:opacity-100">
              <span class="font-mono text-xs text-accent">STATUS: {card.status}</span>
              <span class="material-symbols-outlined text-sm text-accent">{card.statusIcon}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom UI Decor -->
    <div class="mt-24 flex items-center justify-between border-t border-white/10 pt-6">
      <div class="flex gap-4">
        <div class="h-1 w-12 bg-accent/50 skew-x-12"></div>
        <div class="h-1 w-4 bg-accent/30 skew-x-12"></div>
        <div class="h-1 w-2 bg-primary/30 skew-x-12"></div>
      </div>
      <div class="font-mono text-xs text-white/30 tracking-widest uppercase">
        {t(lang, 'identity.scroll')}
      </div>
    </div>
  </div>
</main>
