---
import { t, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const cardsData = [
  {
    id: 0,
    module: (t(lang, 'systems.cards.engineering.status') as string).split('\n')[0],
    title: t(lang, 'systems.cards.engineering.title'),
    icon: 'architecture',
    desc: t(lang, 'systems.cards.engineering.desc'),
    tags: [t(lang, 'systems.cards.engineering.footer')],
    statusLabel: (t(lang, 'systems.cards.engineering.status') as string).split('\n')[1],
    svgId: 'engineering',
  },
  {
    id: 1,
    module: 'MODULE_02',
    title: t(lang, 'systems.cards.ai.title'),
    icon: 'neurology',
    desc: t(lang, 'systems.cards.ai.desc'),
    tags: ['NEURAL_NET', 'DEEP_LEARNING'],
    statusLabel: (t(lang, 'systems.cards.engineering.status') as string).split('\n')[1],
    svgId: 'ai',
  },
  {
    id: 2,
    module: (t(lang, 'systems.cards.bi.status') as string).split('\n')[0],
    title: t(lang, 'systems.cards.bi.title'),
    icon: 'monitoring',
    desc: t(lang, 'systems.cards.bi.desc'),
    tags: [t(lang, 'systems.cards.bi.footer')],
    statusLabel: (t(lang, 'systems.cards.bi.status') as string).split('\n')[1],
    svgId: 'bi',
  },
  {
    id: 3,
    module: (t(lang, 'systems.cards.staff.status') as string).split('\n')[0],
    title: t(lang, 'systems.cards.staff.title'),
    icon: 'groups',
    desc: t(lang, 'systems.cards.staff.desc'),
    tags: [t(lang, 'systems.cards.staff.footer')],
    statusLabel: (t(lang, 'systems.cards.staff.status') as string).split('\n')[1],
    svgId: 'staff',
  },
  {
    id: 4,
    module: (t(lang, 'systems.cards.consulting.status') as string).split('\n')[0],
    title: t(lang, 'systems.cards.consulting.title'),
    icon: 'strategy',
    desc: t(lang, 'systems.cards.consulting.desc'),
    tags: [t(lang, 'systems.cards.consulting.footer')],
    statusLabel: (t(lang, 'systems.cards.consulting.status') as string).split('\n')[1],
    svgId: 'consulting',
  },
];
---

<main class="relative min-h-screen flex flex-col justify-center pt-24 pb-12 overflow-hidden w-full flex-grow">
  <div class="container mx-auto px-6 lg:px-12 relative z-10 flex flex-col h-full">
    <!-- Section Header -->
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-white/10 pb-6">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="text-accent font-mono text-xs tracking-widest">{t(lang, 'systems.secLabel')}</span>
          <div class="h-[1px] w-12 bg-accent/50"></div>
        </div>
        <h1 class="text-4xl md:text-6xl font-bold uppercase tracking-tighter leading-none bg-gradient-to-r from-white via-slate-200 to-slate-500 bg-clip-text text-transparent">
          {t(lang, 'systems.title1')}<br />{t(lang, 'systems.title2')}
        </h1>
      </div>
      <div class="md:text-right">
        <p class="font-tech text-slate-400 text-lg uppercase tracking-wider">{t(lang, 'systems.subtitle')}</p>
        <div class="flex justify-end gap-1 mt-2 font-mono text-xs text-primary">
          <span>///</span><span>SCROLL_X</span><span>///</span>
        </div>
      </div>
    </div>

    <!-- Value Proposition -->
    <p class="font-tech text-slate-300 text-base md:text-lg max-w-3xl mb-10 border-l-2 border-accent/50 pl-5 leading-relaxed">
      {t(lang, 'systems.intro')}
    </p>

    <!-- Service Deck — infinite auto-scroll marquee -->
    <div class="relative w-full overflow-hidden pb-4 pt-4 -mx-0" style="mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);">
      <div id="services-carousel" class="flex gap-6 items-stretch h-[500px] services-marquee">
        <!-- First set -->
        {cardsData.map((card) => (
          <div class="shrink-0 group relative transition-all duration-500 w-[85vw] md:w-[320px] lg:w-[380px] hover:w-[85vw] md:hover:w-[420px] lg:hover:w-[480px] opacity-70 hover:opacity-100 grayscale hover:grayscale-0">
          <div class="absolute -inset-[1px] bg-gradient-to-b from-accent via-primary to-accent rounded-tl-2xl rounded-br-2xl opacity-0 group-hover:opacity-70 blur-sm transition-opacity duration-500"></div>
          <div class="h-full glass-morph flex flex-col relative overflow-hidden rounded-tl-2xl rounded-br-2xl transition-all duration-500 group-hover:bg-void/80 border-l border-white/5 group-hover:border-transparent">
            <div class="absolute top-0 left-0 w-full h-[2px] bg-accent shadow-[0_0_15px_#62C3F6] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute bottom-0 right-0 w-16 h-16 border-r-2 border-b-2 border-accent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-slate-700 opacity-100 group-hover:opacity-0 transition-opacity duration-500"></div>
            <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-slate-700 opacity-100 group-hover:opacity-0 transition-opacity duration-500"></div>

            <div class="h-1/2 w-full flex items-center justify-center relative overflow-hidden transition-colors duration-500 bg-gradient-to-b from-white/5 to-transparent group-hover:from-primary/10">
              <div class="absolute inset-0 bg-[linear-gradient(rgba(98,195,246,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(98,195,246,0.05)_1px,transparent_1px)] bg-[size:20px_20px] [mask-image:radial-gradient(ellipse_at_center,black,transparent)] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-accent/10 to-transparent opacity-100 group-hover:opacity-0 transition-opacity duration-500"></div>

              <div class="relative w-32 h-32 md:w-40 md:h-40 flex justify-center items-center transition-all duration-500">
                {card.svgId === 'engineering' && (
                  <svg class="w-full h-full animate-[spin_20s_linear_infinite] text-slate-500 group-hover:text-accent transition-colors duration-500" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 200 200">
                    <path d="M100 20 L180 60 L180 140 L100 180 L20 140 L20 60 Z" opacity="0.8"></path>
                    <path d="M100 20 L100 180 M20 60 L180 60 M20 140 L180 140" opacity="0.4"></path>
                    <rect class="animate-[pulse_1s_ease-in-out_infinite]" height="80" stroke-dasharray="4 4" width="80" x="60" y="60"></rect>
                  </svg>
                )}
                {card.svgId === 'ai' && (
                  <Fragment>
                    <div class="absolute inset-0 bg-accent/20 blur-[40px] rounded-full animate-pulse-slow opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <svg class="w-full h-full animate-[spin_15s_linear_infinite] text-slate-500 group-hover:text-accent transition-colors duration-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 200 200">
                      <circle cx="100" cy="100" r="40" stroke-dasharray="2 4"></circle>
                      <circle cx="100" cy="100" r="70" stroke-opacity="0.3"></circle>
                      <path d="M100 20 L100 180 M20 100 L180 100" stroke-opacity="0.2"></path>
                      <circle cx="100" cy="30" fill="currentColor" r="4"></circle>
                      <circle cx="170" cy="100" fill="currentColor" r="4"></circle>
                      <circle cx="100" cy="170" fill="currentColor" r="4"></circle>
                      <circle cx="30" cy="100" fill="currentColor" r="4"></circle>
                      <path d="M100 30 L170 100 L100 170 L30 100 Z" stroke-opacity="0.5"></path>
                    </svg>
                  </Fragment>
                )}
                {card.svgId === 'bi' && (
                  <svg class="w-full h-full text-slate-500 group-hover:text-accent transition-colors duration-500" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 200 200">
                    <path d="M30 170 L170 170 M30 170 L30 30" stroke-width="2"></path>
                    <path class="animate-[pulse_1s_ease-in-out_infinite]" d="M30 150 L60 120 L90 140 L120 80 L150 100 L170 50" stroke-width="2"></path>
                    <path d="M30 170 L50 190 L190 190 L170 170" opacity="0.3"></path>
                    <path d="M190 190 L190 50 L170 30" opacity="0.3"></path>
                  </svg>
                )}
                {card.svgId === 'staff' && (
                  <svg class="w-full h-full text-slate-500 group-hover:text-accent transition-colors duration-500 animate-[spin_25s_linear_infinite]" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 200 200">
                    <circle cx="100" cy="60" r="30"></circle>
                    <path d="M50 180 C50 130 150 130 150 180"></path>
                    <circle cx="100" cy="100" r="80" stroke-dasharray="2 6"></circle>
                    <circle cx="30" cy="100" fill="currentColor" r="5"></circle>
                    <circle cx="170" cy="100" fill="currentColor" r="5"></circle>
                  </svg>
                )}
                {card.svgId === 'consulting' && (
                  <svg class="w-full h-full text-slate-500 group-hover:text-accent transition-colors duration-500 animate-[spin_30s_linear_infinite]" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 200 200">
                    <circle cx="100" cy="100" r="70"></circle>
                    <ellipse cx="100" cy="100" rx="70" ry="20" transform="rotate(45 100 100)"></ellipse>
                    <ellipse cx="100" cy="100" rx="70" ry="20" transform="rotate(-45 100 100)"></ellipse>
                    <path d="M100 30 L100 170" stroke-dasharray="4 4"></path>
                    <path d="M30 100 L170 100" stroke-dasharray="4 4"></path>
                  </svg>
                )}
              </div>

              <div class="absolute top-6 right-6 font-mono text-xs text-accent text-right opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                <span class="animate-[pulse_1s_ease-in-out_infinite]">{t(lang, 'systems.cards.ai.live')}</span><br />
                {t(lang, 'systems.cards.ai.processing')}
              </div>

              <div class="absolute top-4 left-4 font-mono text-[10px] text-accent opacity-100 group-hover:opacity-0 transition-opacity duration-500">
                {card.module}<br />{card.statusLabel}
              </div>
            </div>

            <div class="flex-1 p-6 md:p-8 flex flex-col justify-end relative z-10 transition-all duration-300">
              <div class="mb-auto">
                <span class="material-symbols-outlined text-4xl text-accent mb-4 transition-all duration-500 group-hover:drop-shadow-[0_0_8px_rgba(98,195,246,0.8)]">{card.icon}</span>
              </div>
              <h3 class="font-bold mb-2 transition-all duration-500 text-2xl md:text-3xl text-slate-200 group-hover:text-white">{card.title}</h3>
              <p class="font-tech leading-tight mb-6 max-w-[90%] transition-all duration-500 text-slate-400 text-lg group-hover:text-slate-100 border-l-[0px] border-transparent group-hover:border-l-2 group-hover:border-accent group-hover:pl-4 pl-0">
                {card.desc}
              </p>
              <div class="flex items-center justify-between mt-auto transition-all duration-500 border-t border-white/10 pt-4 group-hover:border-transparent group-hover:pt-0">
                <div class="flex gap-2">
                  {card.tags.map(tag => (
                    <span class="font-mono transition-all duration-500 text-xs text-slate-500 border border-transparent group-hover:px-2 group-hover:py-1 group-hover:bg-accent/10 group-hover:border-accent/30 group-hover:text-accent group-hover:text-[10px] group-hover:rounded">
                      {tag}
                    </span>
                  ))}
                </div>
                <button class="text-accent transition-all duration-500 group-hover:bg-accent group-hover:text-void flex items-center justify-center rounded-sm bg-transparent group-hover:p-2 hover:group-hover:bg-white group-hover:opacity-100 opacity-50">
                  <span class="material-symbols-outlined">arrow_forward</span>
                </button>
              </div>
            </div>
          </div>
        </div>
        ))}
        <!-- Second set — exact duplicate for seamless loop -->
        {cardsData.map((card) => (
          <div class="shrink-0 group relative transition-all duration-500 w-[85vw] md:w-[320px] lg:w-[380px] hover:w-[85vw] md:hover:w-[420px] lg:hover:w-[480px] opacity-70 hover:opacity-100 grayscale hover:grayscale-0" aria-hidden="true">
            <div class="absolute -inset-[1px] bg-gradient-to-b from-accent via-primary to-accent rounded-tl-2xl rounded-br-2xl opacity-0 group-hover:opacity-70 blur-sm transition-opacity duration-500"></div>
            <div class="h-full glass-morph flex flex-col relative overflow-hidden rounded-tl-2xl rounded-br-2xl transition-all duration-500 group-hover:bg-void/80 border-l border-white/5 group-hover:border-transparent">
              <div class="absolute top-0 left-0 w-full h-[2px] bg-accent shadow-[0_0_15px_#62C3F6] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="absolute bottom-0 right-0 w-16 h-16 border-r-2 border-b-2 border-accent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-slate-700 opacity-100 group-hover:opacity-0 transition-opacity duration-500"></div>
              <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-slate-700 opacity-100 group-hover:opacity-0 transition-opacity duration-500"></div>
              <div class="h-1/2 w-full flex items-center justify-center relative overflow-hidden transition-colors duration-500 bg-gradient-to-b from-white/5 to-transparent group-hover:from-primary/10">
                <div class="absolute inset-0 bg-[linear-gradient(rgba(98,195,246,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(98,195,246,0.05)_1px,transparent_1px)] bg-[size:20px_20px] [mask-image:radial-gradient(ellipse_at_center,black,transparent)] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="relative w-32 h-32 md:w-40 md:h-40 flex justify-center items-center">
                  {card.svgId === 'engineering' && (
                    <svg class="w-full h-full animate-[spin_20s_linear_infinite] text-slate-500 group-hover:text-accent transition-colors duration-500" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 200 200">
                      <path d="M100 20 L180 60 L180 140 L100 180 L20 140 L20 60 Z" opacity="0.8"></path>
                      <path d="M100 20 L100 180 M20 60 L180 60 M20 140 L180 140" opacity="0.4"></path>
                      <rect class="animate-[pulse_1s_ease-in-out_infinite]" height="80" stroke-dasharray="4 4" width="80" x="60" y="60"></rect>
                    </svg>
                  )}
                  {card.svgId === 'ai' && (
                    <svg class="w-full h-full animate-[spin_15s_linear_infinite] text-slate-500 group-hover:text-accent transition-colors duration-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 200 200">
                      <circle cx="100" cy="100" r="40" stroke-dasharray="2 4"></circle>
                      <circle cx="100" cy="100" r="70" stroke-opacity="0.3"></circle>
                      <path d="M100 20 L100 180 M20 100 L180 100" stroke-opacity="0.2"></path>
                      <circle cx="100" cy="30" fill="currentColor" r="4"></circle>
                      <circle cx="170" cy="100" fill="currentColor" r="4"></circle>
                      <circle cx="100" cy="170" fill="currentColor" r="4"></circle>
                      <circle cx="30" cy="100" fill="currentColor" r="4"></circle>
                      <path d="M100 30 L170 100 L100 170 L30 100 Z" stroke-opacity="0.5"></path>
                    </svg>
                  )}
                  {card.svgId === 'bi' && (
                    <svg class="w-full h-full text-slate-500 group-hover:text-accent transition-colors duration-500" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 200 200">
                      <path d="M30 170 L170 170 M30 170 L30 30" stroke-width="2"></path>
                      <path class="animate-[pulse_1s_ease-in-out_infinite]" d="M30 150 L60 120 L90 140 L120 80 L150 100 L170 50" stroke-width="2"></path>
                    </svg>
                  )}
                  {card.svgId === 'staff' && (
                    <svg class="w-full h-full text-slate-500 group-hover:text-accent transition-colors duration-500 animate-[spin_25s_linear_infinite]" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 200 200">
                      <circle cx="100" cy="60" r="30"></circle>
                      <path d="M50 180 C50 130 150 130 150 180"></path>
                      <circle cx="100" cy="100" r="80" stroke-dasharray="2 6"></circle>
                      <circle cx="30" cy="100" fill="currentColor" r="5"></circle>
                      <circle cx="170" cy="100" fill="currentColor" r="5"></circle>
                    </svg>
                  )}
                  {card.svgId === 'consulting' && (
                    <svg class="w-full h-full text-slate-500 group-hover:text-accent transition-colors duration-500 animate-[spin_30s_linear_infinite]" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 200 200">
                      <circle cx="100" cy="100" r="70"></circle>
                      <ellipse cx="100" cy="100" rx="70" ry="20" transform="rotate(45 100 100)"></ellipse>
                      <ellipse cx="100" cy="100" rx="70" ry="20" transform="rotate(-45 100 100)"></ellipse>
                      <path d="M100 30 L100 170" stroke-dasharray="4 4"></path>
                      <path d="M30 100 L170 100" stroke-dasharray="4 4"></path>
                    </svg>
                  )}
                </div>
                <div class="absolute top-4 left-4 font-mono text-[10px] text-accent opacity-100 group-hover:opacity-0 transition-opacity duration-500">
                  {card.module}<br />{card.statusLabel}
                </div>
              </div>
              <div class="flex-1 p-6 md:p-8 flex flex-col justify-end relative z-10">
                <div class="mb-auto">
                  <span class="material-symbols-outlined text-4xl text-accent mb-4 transition-all duration-500 group-hover:drop-shadow-[0_0_8px_rgba(98,195,246,0.8)]">{card.icon}</span>
                </div>
                <h3 class="font-bold mb-2 text-2xl md:text-3xl text-slate-200 group-hover:text-white">{card.title}</h3>
                <p class="font-tech leading-tight mb-6 max-w-[90%] text-slate-400 text-lg group-hover:text-slate-100 group-hover:border-l-2 group-hover:border-accent group-hover:pl-4 pl-0 transition-all duration-500">
                  {card.desc}
                </p>
                <div class="flex items-center justify-between mt-auto border-t border-white/10 pt-4 group-hover:border-transparent group-hover:pt-0 transition-all duration-500">
                  <div class="flex gap-2">
                    {card.tags.map(tag => (
                      <span class="font-mono text-xs text-slate-500 group-hover:px-2 group-hover:py-1 group-hover:bg-accent/10 group-hover:border group-hover:border-accent/30 group-hover:text-accent group-hover:text-[10px] group-hover:rounded transition-all duration-500">{tag}</span>
                    ))}
                  </div>
                  <button class="text-accent group-hover:bg-accent group-hover:text-void flex items-center justify-center rounded-sm bg-transparent group-hover:p-2 opacity-50 group-hover:opacity-100 transition-all duration-500">
                    <span class="material-symbols-outlined">arrow_forward</span>
                  </button>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Indicador de movimiento -->
    <div class="mt-6 flex items-center justify-center gap-3">
      <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-accent/50"></div>
      <span class="material-symbols-outlined text-sm text-accent/50 animate-[pulse_2s_ease-in-out_infinite]">swap_horiz</span>
      <div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-accent/50"></div>
    </div>

  </div>
</main>

<style>
  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .services-marquee {
    animation: marquee-scroll 50s linear infinite;
    width: max-content;
  }

  .services-marquee:hover {
    animation-play-state: paused;
  }
</style>
