---
import { t, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<main class="relative z-10 flex-grow w-full flex items-center justify-center px-6 overflow-hidden">
  <div class="max-w-[1440px] w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-0 items-center relative h-full py-12 lg:py-0">
    <!-- Left Column: Typography & Action -->
    <div class="flex flex-col gap-8 z-20 order-2 lg:order-1">
      <!-- Decorative Label -->
      <div class="flex items-center gap-3">
        <div class="h-[1px] w-12 bg-accent/50"></div>
        <span class="font-mono text-accent text-xs tracking-[0.2em]">{t(lang, 'home.protocol')}</span>
      </div>
      <!-- Main Heading -->
      <div class="relative">
        <h1 class="font-display font-bold text-6xl md:text-7xl lg:text-[5.5rem] leading-[0.9] tracking-tighter text-white uppercase">
          {t(lang, 'home.title1')} <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent via-primary to-primary bg-[length:200%_auto] animate-pulse-glow">{t(lang, 'home.title2')}</span>
        </h1>
        <div class="absolute -z-10 -top-10 -left-10 w-40 h-40 bg-primary/20 blur-3xl rounded-full"></div>
      </div>
      <!-- Subtitle -->
      <p class="font-tech text-lg md:text-xl text-muted max-w-lg border-l-2 border-primary/50 pl-6 py-1">
        {t(lang, 'home.subtitle')}
      </p>
      <!-- CTA Area -->
      <div class="pt-6 flex flex-wrap gap-6 items-center">
        <button class="group relative px-8 py-4 bg-accent text-void font-bold font-display tracking-widest uppercase text-sm overflow-hidden transition-all hover:scale-105 hover:shadow-[0_0_30px_rgba(98,195,246,0.6)] -skew-x-[12deg] glitch-hover">
          <span class="relative z-10 flex items-center gap-2 skew-x-[12deg]">
            {t(lang, 'home.initProject')}
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </span>
          <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
        </button>
        <a class="font-mono text-sm text-white/70 hover:text-accent flex items-center gap-2 group transition-colors no-underline" href="#">
          <span class="w-8 h-[1px] bg-white/30 group-hover:bg-accent transition-colors"></span>
          {t(lang, 'home.viewCaps')}
        </a>
      </div>
      <!-- Bottom Metrics (Decor) -->
      <div class="mt-12 flex gap-8 font-mono text-[10px] text-white/40">
        <div>
          <span class="block text-accent mb-1">{t(lang, 'home.metrics.latency')}</span>
          {t(lang, 'home.metrics.latencyValue')}
        </div>
        <div>
          <span class="block text-accent mb-1">{t(lang, 'home.metrics.uptime')}</span>
          {t(lang, 'home.metrics.uptimeValue')}
        </div>
        <div>
          <span class="block text-accent mb-1">{t(lang, 'home.metrics.encryption')}</span>
          {t(lang, 'home.metrics.encryptionValue')}
        </div>
      </div>
    </div>

    <!-- Right Column: Visual Anchor -->
    <div class="relative flex items-center justify-center min-h-[600px] lg:min-h-[800px] order-1 lg:order-2 w-full lg:w-[110%] lg:-ml-[5%]" style="perspective: 1000px;">

      <!-- Background Orbit/Rings System -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none translate-x-[20%] lg:translate-x-[30%] opacity-40">
        <div class="w-[450px] h-[450px] md:w-[750px] md:h-[750px] rounded-full border border-white/5 animate-spin-slow absolute"></div>
        <div class="w-[350px] h-[350px] md:w-[600px] md:h-[600px] rounded-full border border-dashed border-accent/20 animate-spin-reverse-slow absolute"></div>
        <div class="w-[250px] h-[250px] md:w-[450px] md:h-[450px] rounded-full border border-primary/30 shadow-[0_0_40px_rgba(109,40,217,0.3)] animate-pulse-glow absolute"></div>
        <div class="absolute w-[750px] h-[750px] animate-spin-slow hidden md:block">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-void border border-accent/50 px-2 py-0.5 text-[8px] font-mono text-accent rounded-sm backdrop-blur-sm">NODE_ALFA</div>
        </div>
        <div class="absolute w-[600px] h-[600px] animate-spin-reverse-slow hidden md:block">
          <div class="absolute bottom-[10%] right-[10%] bg-void border border-primary/50 px-2 py-0.5 text-[8px] font-mono text-primary rounded-sm backdrop-blur-sm">DATA_STREAM</div>
        </div>
      </div>

      <!-- AI & Data Analytics Central Core -->
      <div class="relative z-10 w-full h-[600px] lg:h-[800px]">

        <!-- Central Corporate Panel -->
        <div class="absolute right-[-50%] top-1/2 -translate-y-1/2 z-10 w-[260px] lg:w-[340px] min-h-[350px] glass-panel p-10 rounded-lg cyber-corner border border-primary/50 bg-void/90 backdrop-blur-xl shadow-[0_0_50px_rgba(109,40,217,0.2)] flex flex-col justify-center">
          <div class="text-center mb-6">
            <h2 class="font-mono text-accent text-base tracking-[0.3em] uppercase">{lang === 'es' ? 'QUIENES SOMOS' : 'WHO WE ARE'}</h2>
          </div>
          <p class="font-tech text-white/80 text-sm xl:text-base leading-relaxed text-center">
            {lang === 'es'
              ? 'TEKOSOFT S.A.S. es una firma de ingeniería dedicada al desarrollo, consultoría y comercialización de soluciones informáticas integrales. Nuestra operación abarca desde IA y analítica de datos (BI) hasta la exportación de servicios de ingeniería con estándares globales.'
              : 'TEKOSOFT S.A.S. is an engineering firm dedicated to the development, consulting and commercialization of comprehensive IT solutions. Our operations range from AI and data analytics (BI) to exporting engineering services with global standards.'}
          </p>
        </div>

        <!-- Module 1: Software Engineering -->
        <div class="absolute top-[-35%] left-[20%] glass-panel p-3 rounded-lg cyber-corner animate-float z-20 shadow-neon border-t border-l border-accent/40 bg-void/80 backdrop-blur-md hidden sm:block w-[240px]">
          <div class="flex items-center gap-2 mb-2 border-b border-white/10 pb-1.5">
            <span class="material-symbols-outlined text-primary text-[14px]">code</span>
            <span class="font-mono text-[9px] text-muted tracking-wide uppercase">{t(lang, 'home.liveStats.service1')}</span>
          </div>
          <div class="font-display font-bold text-base text-white whitespace-nowrap">{t(lang, 'home.liveStats.service1Title')}</div>
          <div class="text-[7px] font-mono text-accent/80 tracking-widest mt-1 uppercase">{t(lang, 'home.liveStats.service1Desc')}</div>
        </div>

        <!-- Module 2: AI -->
        <div class="absolute top-[-30%] left-[5%] glass-panel p-3 rounded-lg cyber-corner animate-float z-20 shadow-neon border-l border-primary/40 bg-void/80 backdrop-blur-md hidden sm:block w-[240px]" style="animation-delay: 0.4s;">
          <div class="flex items-center justify-between mb-2 border-b border-white/10 pb-1.5">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-[14px]">psychology</span>
              <span class="font-mono text-[9px] text-primary tracking-wide uppercase">{t(lang, 'home.liveStats.service2')}</span>
            </div>
            <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-ping"></span>
          </div>
          <div class="font-display font-bold text-base text-white whitespace-nowrap">{t(lang, 'home.liveStats.service2Title')}</div>
          <div class="text-[7px] font-mono text-muted tracking-widest mt-1 uppercase">{t(lang, 'home.liveStats.service2Desc')}</div>
        </div>

        <!-- Module 3: BI -->
        <div class="absolute top-[-25%] left-[0%] glass-panel p-3 rounded-lg cyber-corner animate-float z-20 shadow-neon border-l border-accent/40 bg-void/80 backdrop-blur-md hidden sm:block w-[240px]" style="animation-delay: 0.8s;">
          <div class="flex items-center gap-2 mb-2 border-b border-white/10 pb-1.5">
            <span class="material-symbols-outlined text-accent text-[14px]">monitoring</span>
            <span class="font-mono text-[9px] text-muted tracking-wide uppercase">{t(lang, 'home.liveStats.service3')}</span>
          </div>
          <div class="font-display font-bold text-base text-white whitespace-nowrap">{t(lang, 'home.liveStats.service3Title')}</div>
          <div class="text-[7px] font-mono text-muted tracking-widest mt-1 uppercase">{t(lang, 'home.liveStats.service3Desc')}</div>
        </div>

        <!-- Module 4: Staff Augmentation -->
        <div class="absolute top-[-20%] left-[5%] glass-panel p-3 rounded-lg cyber-corner animate-float z-20 shadow-neon border-b border-l border-primary/40 bg-void/80 backdrop-blur-md hidden sm:block w-[240px]" style="animation-delay: 1.2s;">
          <div class="flex items-center gap-2 mb-2 border-b border-white/10 pb-1.5">
            <span class="material-symbols-outlined text-primary text-[14px]">groups</span>
            <span class="font-mono text-[9px] text-muted tracking-wide uppercase">{t(lang, 'home.liveStats.service4')}</span>
          </div>
          <div class="font-display font-bold text-base text-white whitespace-nowrap">{t(lang, 'home.liveStats.service4Title')}</div>
          <div class="text-[7px] font-mono text-muted tracking-widest mt-1 uppercase">{t(lang, 'home.liveStats.service4Desc')}</div>
        </div>

        <!-- Module 5: Strategic Consulting -->
        <div class="absolute top-[-15%] left-[20%] glass-panel p-3 rounded-lg cyber-corner animate-float z-20 shadow-neon border-b border-accent/40 bg-void/80 backdrop-blur-md hidden sm:block w-[240px]" style="animation-delay: 1.6s;">
          <div class="flex items-center gap-2 mb-2 border-b border-white/10 pb-1.5">
            <span class="material-symbols-outlined text-accent text-[14px]">lightbulb</span>
            <span class="font-mono text-[9px] text-muted tracking-wide uppercase">{t(lang, 'home.liveStats.service5')}</span>
          </div>
          <div class="font-display font-bold text-base text-white whitespace-nowrap">{t(lang, 'home.liveStats.service5Title')}</div>
          <div class="text-[7px] font-mono text-muted tracking-widest mt-1 uppercase">{t(lang, 'home.liveStats.service5Title')}</div>
        </div>

        <!-- Neural Network SVG Lines -->
        <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-40 z-0 hidden lg:block overflow-visible">
          <line x1="70%" y1="40%" x2="35%" y2="15%" stroke="url(#cyan-purple)" stroke-width="1.5" stroke-dasharray="4 4" class="animate-[pulse_3s_linear_infinite]" />
          <circle cx="35%" cy="15%" r="4" fill="#62C3F6" class="animate-ping" />
          <line x1="70%" y1="43%" x2="20%" y2="30%" stroke="url(#cyan-purple)" stroke-width="1.5" stroke-dasharray="4 4" class="animate-[pulse_4s_linear_infinite]" />
          <circle cx="20%" cy="30%" r="4" fill="#6D28D9" class="animate-ping" />
          <line x1="70%" y1="50%" x2="15%" y2="47%" stroke="#62C3F6" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.6" class="animate-[pulse_3s_linear_infinite]" />
          <circle cx="15%" cy="47%" r="3" fill="#62C3F6" opacity="0.6" />
          <line x1="70%" y1="55%" x2="20%" y2="63%" stroke="#6D28D9" stroke-width="1" stroke-dasharray="2 4" opacity="0.5" />
          <circle cx="20%" cy="63%" r="3" fill="#6D28D9" opacity="0.5" />
          <line x1="70%" y1="58%" x2="35%" y2="78%" stroke="url(#cyan-purple)" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.7" />
          <circle cx="35%" cy="78%" r="3" fill="#62C3F6" opacity="0.7" />
          <defs>
            <linearGradient id="cyan-purple" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#62C3F6" />
              <stop offset="100%" stop-color="#6D28D9" />
            </linearGradient>
          </defs>
        </svg>
      </div>
    </div>
  </div>
</main>
