---
import { getCollection } from 'astro:content';
import { t, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.data.lang === lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<main class="relative z-10 flex-grow w-full flex flex-col items-center py-20 px-4 md:px-8">
  <div class="max-w-5xl w-full mx-auto">
    <!-- Section Header -->
    <header class="mb-16 relative">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-[1px] w-12 bg-accent/50"></div>
        <span class="font-mono text-accent text-xs tracking-[0.2em]">BLOG</span>
      </div>
      <h1 class="font-display font-bold text-5xl md:text-6xl lg:text-7xl leading-tight text-white uppercase">
        {lang === 'es' ? 'Nuestro' : 'Our'} <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-primary">Blog</span>
      </h1>
      <p class="font-tech text-lg text-muted mt-4 max-w-2xl border-l-2 border-primary/50 pl-6">
        {lang === 'es'
          ? 'Artículos sobre desarrollo de software, inteligencia artificial, business intelligence y tendencias tecnológicas.'
          : 'Articles about software development, artificial intelligence, business intelligence and technology trends.'}
      </p>
    </header>

    <!-- Posts Grid -->
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {posts.map(post => {
          const formattedDate = post.data.date.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <a href={`/${lang}/blog/${post.data.slug}`} class="group block no-underline">
              <article class="glass-panel p-8 rounded-xl transition-all duration-300 hover:border-accent/40 hover:shadow-[0_0_20px_rgba(98,195,246,0.15)] hover:-translate-y-1 h-full flex flex-col">
                {post.data.image && (
                  <div class="w-full h-48 rounded-lg overflow-hidden mb-6 border border-white/5">
                    <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                  </div>
                )}
                <time class="font-mono text-xs text-accent/70 tracking-widest" datetime={post.data.date.toISOString()}>
                  {formattedDate}
                </time>
                <h2 class="font-display font-bold text-2xl text-white mt-3 mb-3 group-hover:text-accent transition-colors">
                  {post.data.title}
                </h2>
                <p class="font-tech text-muted text-base leading-relaxed flex-grow">
                  {post.data.description}
                </p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-4">
                    {post.data.tags.map(tag => (
                      <span class="text-[10px] font-mono bg-white/5 border border-white/10 px-2 py-0.5 rounded text-slate-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <div class="mt-6 pt-4 border-t border-white/5 flex items-center justify-between">
                  <span class="font-mono text-xs text-accent group-hover:text-white transition-colors">
                    {lang === 'es' ? 'Leer más' : 'Read more'}
                  </span>
                  <span class="material-symbols-outlined text-sm text-accent group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </div>
              </article>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="glass-panel p-12 rounded-xl text-center">
        <span class="material-symbols-outlined text-4xl text-accent/50 mb-4 block">article</span>
        <p class="font-tech text-muted text-lg">
          {lang === 'es' ? 'Próximamente publicaremos artículos aquí.' : 'We will publish articles here soon.'}
        </p>
      </div>
    )}
  </div>
</main>
