---
import { t, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<main class="relative z-10 flex-grow flex flex-col items-center justify-center py-16 px-6 overflow-hidden w-full">
  <div class="w-full max-w-7xl relative">
    <!-- Section Header -->
    <div class="flex flex-wrap justify-between items-end gap-6 mb-12 border-l-2 border-accent pl-6 py-2 relative">
      <div class="absolute -top-10 left-[-2px] h-10 w-0.5 bg-gradient-to-t from-accent to-transparent"></div>
      <div class="flex flex-col gap-1">
        <h2 class="text-5xl md:text-6xl font-bold tracking-tighter text-white font-display uppercase">
          {t(lang, 'expertise.title1')} <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-primary">{t(lang, 'expertise.title2')}</span>
        </h2>
        <div class="flex items-center gap-3 font-mono text-xs text-accent/80 tracking-widest mt-2">
          <span class="material-symbols-outlined text-sm">terminal</span>
          <span>{t(lang, 'expertise.secLabel')}</span>
        </div>
      </div>
      <div class="hidden md:block text-right">
        <p class="text-muted font-tech text-lg max-w-md leading-tight">
          {t(lang, 'expertise.subtitle')}
        </p>
      </div>
    </div>

    <!-- Bento Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-5 relative">
      <!-- 1. Core Architecture (Large Block) -->
      <div class="col-span-1 md:col-span-8 glass-panel rounded-lg p-8 group relative overflow-hidden transition-all duration-300 hover:border-accent/40 hover:shadow-[0_0_30px_rgba(109,40,217,0.15)]">
        <div class="corner-bracket corner-tl"></div>
        <div class="corner-bracket corner-tr"></div>
        <div class="flex justify-between items-start mb-6 border-b border-white/5 pb-4">
          <h3 class="font-tech font-bold text-xl uppercase tracking-widest text-white flex items-center gap-2">
            <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
            {t(lang, 'expertise.cards.core.title')}
          </h3>
          <span class="font-mono text-xs text-muted opacity-50">{t(lang, 'expertise.cards.core.mod')}</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 relative z-10">
          <div>
            <span class="text-xs font-mono text-accent mb-3 block uppercase">{t(lang, 'expertise.cards.core.backend')}</span>
            <div class="flex flex-wrap gap-2">
              {['Node.js', 'Rust', 'GoLang', 'Python', 'PostgreSQL', 'GraphQL'].map(tech => (
                <span class="tech-tag bg-white/5 border border-white/10 px-3 py-1.5 text-sm font-medium rounded-full text-slate-300 transition-all duration-200 hover:bg-accent/10 hover:border-accent hover:text-accent hover:shadow-[0_0_10px_rgba(98,195,246,0.2)] hover:-translate-y-px">{tech}</span>
              ))}
            </div>
          </div>
          <div>
            <span class="text-xs font-mono text-accent mb-3 block uppercase">{t(lang, 'expertise.cards.core.frontend')}</span>
            <div class="flex flex-wrap gap-2">
              {['React', 'Next.js 14', 'Vue 3', 'Tailwind CSS', 'Three.js', 'WebGL'].map(tech => (
                <span class="tech-tag bg-white/5 border border-white/10 px-3 py-1.5 text-sm font-medium rounded-full text-slate-300 transition-all duration-200 hover:bg-accent/10 hover:border-accent hover:text-accent hover:shadow-[0_0_10px_rgba(98,195,246,0.2)] hover:-translate-y-px">{tech}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- 2. AI & Intelligence (Tall Block) -->
      <div class="col-span-1 md:col-span-4 row-span-2 glass-panel rounded-lg p-6 flex flex-col justify-between transition-all duration-300 hover:border-accent/40 hover:shadow-[0_0_30px_rgba(109,40,217,0.15)]">
        <div>
          <div class="flex justify-between items-center mb-6 border-b border-white/5 pb-4">
            <h3 class="font-tech font-bold text-xl uppercase tracking-widest text-white">{t(lang, 'expertise.cards.ai.title')}</h3>
            <span class="material-symbols-outlined text-accent">neurology</span>
          </div>
          <div class="flex flex-col gap-4">
            <div>
              <div class="flex justify-between text-sm font-mono text-slate-400 mb-1">
                <span>{t(lang, 'expertise.cards.ai.llm')}</span>
                <span class="text-accent">98%</span>
              </div>
              <div class="h-1 w-full bg-void rounded-full overflow-hidden">
                <div class="h-full bg-accent w-[98%] shadow-[0_0_10px_#62C3F6]"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm font-mono text-slate-400 mb-1">
                <span>{t(lang, 'expertise.cards.ai.cv')}</span>
                <span class="text-accent">85%</span>
              </div>
              <div class="h-1 w-full bg-void rounded-full overflow-hidden">
                <div class="h-full bg-primary w-[85%]"></div>
              </div>
            </div>
          </div>
          <div class="mt-8 flex flex-wrap gap-2">
            {['TensorFlow', 'PyTorch', 'OpenAI API', 'HuggingFace'].map(tech => (
              <span class="bg-white/5 border border-accent/30 px-2 py-1 text-xs font-bold rounded uppercase text-slate-300">{tech}</span>
            ))}
          </div>
        </div>
        <div class="mt-8 pt-4 border-t border-dashed border-white/10">
          <div class="flex items-center gap-2 text-xs font-mono text-muted">
            <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-ping"></span>
            <span>{t(lang, 'expertise.cards.ai.training')}</span>
          </div>
        </div>
      </div>

      <!-- 3. Infrastructure (Medium Block) -->
      <div class="col-span-1 md:col-span-4 glass-panel rounded-lg p-6 transition-all duration-300 hover:border-accent/40 hover:shadow-[0_0_30px_rgba(109,40,217,0.15)]">
        <div class="flex justify-between items-start mb-4">
          <h3 class="font-tech font-bold text-lg uppercase tracking-widest text-white">{t(lang, 'expertise.cards.infra.title')}</h3>
          <span class="material-symbols-outlined text-muted text-lg">cloud_queue</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {['AWS', 'Azure', 'Docker', 'Kubernetes', 'Terraform'].map(tech => (
            <span class="tech-tag bg-white/5 border border-white/10 px-3 py-1.5 text-sm font-medium rounded-full text-slate-300">{tech}</span>
          ))}
        </div>
      </div>

      <!-- 4. Design & Strategy (Medium Block) -->
      <div class="col-span-1 md:col-span-4 glass-panel rounded-lg p-6 relative overflow-hidden transition-all duration-300 hover:border-accent/40 hover:shadow-[0_0_30px_rgba(109,40,217,0.15)]">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent pointer-events-none"></div>
        <div class="flex justify-between items-start mb-4 relative z-10">
          <h3 class="font-tech font-bold text-lg uppercase tracking-widest text-white">{t(lang, 'expertise.cards.design.title')}</h3>
          <span class="material-symbols-outlined text-muted text-lg">design_services</span>
        </div>
        <div class="flex flex-wrap gap-2 relative z-10">
          {['Figma', 'Rive', 'Spline 3D', 'After Effects'].map(tech => (
            <span class="tech-tag bg-white/5 border border-white/10 px-3 py-1.5 text-sm font-medium rounded-full text-slate-300">{tech}</span>
          ))}
        </div>
      </div>

      <!-- 5. Quality Assurance (Small Strip) -->
      <div class="col-span-1 md:col-span-12 glass-panel rounded-lg p-4 flex flex-col md:flex-row items-center justify-between gap-4 transition-all duration-300 hover:border-accent/40 hover:shadow-[0_0_30px_rgba(109,40,217,0.15)]">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded bg-primary/20 flex items-center justify-center border border-primary/50 text-primary">
            <span class="material-symbols-outlined text-lg">verified_user</span>
          </div>
          <div>
            <h3 class="font-tech font-bold text-sm uppercase tracking-widest text-white">{t(lang, 'expertise.cards.qa.title')}</h3>
            <p class="text-xs text-muted">{t(lang, 'expertise.cards.qa.desc')}</p>
          </div>
        </div>
        <div class="flex flex-wrap justify-center gap-4">
          {['CYPRESS', 'JEST', 'SELENIUM'].map(tech => (
            <div class="flex items-center gap-2 px-3 py-1 bg-void/50 rounded border border-white/5">
              <span class="w-1.5 h-1.5 bg-accent rounded-full"></span>
              <span class="text-xs font-mono text-slate-300">{tech}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</main>
